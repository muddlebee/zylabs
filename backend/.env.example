TAVILY_API_KEY=
FIRECRAWL_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Model — pick one provider and set the model name accordingly
# DeepSeek: MODEL_PROVIDER=deepseek  MODEL_NAME=deepseek-chat
# OpenAI:   MODEL_PROVIDER=openai    MODEL_NAME=gpt-4.1-mini
MODEL_NAME=deepseek-chat
MODEL_PROVIDER=deepseek

# Thresholds
QUALITY_THRESHOLD=0.7
MAX_REVISIONS=2

# Storage
DATABASE_URL=sqlite:///./research.db
CHECKPOINT_DB_PATH=./checkpoints.db

LOG_LEVEL=INFO
